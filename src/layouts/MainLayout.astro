---
interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="tr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description ?? 'İstanbul-Letonya karavan yolculuğu planı ve gerçek zamanlı takip paneli'} />
    <title>{title}</title>
    <link rel="icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://unpkg.com" />
    <link rel="preconnect" href="https://www.google.com" />
    <style is:global>
      :root {
        --bg: #050b16;
        --panel: rgba(14, 24, 46, 0.86);
        --text: #e9f1ff;
        --muted: #9eb2d1;
        --line: rgba(120, 150, 210, 0.3);
        --accent: #67a6ff;
        --accent2: #59e0ff;
        --ok: #39d98a;
        --warn: #ffcf66;
        --bad: #ff7088;
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        color: var(--text);
        background:
          radial-gradient(circle at 10% 10%, rgba(103, 166, 255, 0.12), transparent 36%),
          radial-gradient(circle at 90% 30%, rgba(89, 224, 255, 0.08), transparent 30%),
          var(--bg);
        font-family: Inter, ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Helvetica, Arial, sans-serif;
      }

      a {
        color: var(--accent);
        text-decoration: none;
      }

      .container {
        width: min(1120px, 94vw);
        margin: 0 auto;
        padding: 28px 0 56px;
      }

      .shell {
        border: 1px solid var(--line);
        background: var(--panel);
        border-radius: 18px;
        padding: 18px;
        margin-bottom: 16px;
        box-shadow: 0 10px 38px rgba(0, 0, 0, 0.28);
      }

      .hero {
        position: relative;
        overflow: hidden;
      }

      .hero h1 {
        margin: 0;
        font-size: clamp(1.4rem, 3vw, 2rem);
        line-height: 1.2;
      }

      .hero p {
        color: var(--muted);
        margin-top: 8px;
      }

      .hero-image {
        margin-top: 12px;
        border-radius: 14px;
        width: 100%;
        min-height: 180px;
        background: linear-gradient(130deg, rgba(103, 166, 255, 0.16), rgba(89, 224, 255, 0.08));
        object-fit: cover;
      }

      .grid {
        display: grid;
        grid-template-columns: repeat(12, 1fr);
        gap: 14px;
      }

      .card {
        padding: 14px;
        border: 1px solid var(--line);
        border-radius: 14px;
        background: rgba(8, 16, 32, 0.45);
      }

      .muted {
        color: var(--muted);
      }

      .tag-row {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
      }

      .tag {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        border: 1px solid var(--line);
        border-radius: 999px;
        padding: 6px 10px;
        font-size: 12px;
        color: #c6dcff;
        background: rgba(103, 166, 255, 0.12);
      }

      .day-link {
        display: flex;
        justify-content: space-between;
        gap: 10px;
        align-items: baseline;
        margin-bottom: 8px;
      }

      .day-link strong {
        color: #fff;
      }

      .map-frame {
        border: 1px solid var(--line);
        border-radius: 12px;
        overflow: hidden;
        min-height: 360px;
      }

      .map-frame iframe,
      .route-map {
        width: 100%;
        height: 100%;
        min-height: 360px;
        border: 0;
      }

      .header-nav {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin-top: 12px;
      }

      .btn {
        border: 1px solid rgba(103, 166, 255, 0.5);
        background: rgba(103, 166, 255, 0.12);
        color: #d9ecff;
        border-radius: 10px;
        padding: 9px 12px;
        font-weight: 600;
        text-decoration: none;
      }

      .btn:hover {
        background: rgba(103, 166, 255, 0.22);
      }

      .badge-ok {
        color: var(--ok);
      }

      .badge-warn {
        color: var(--warn);
      }

      .badge-bad {
        color: var(--bad);
      }

      .foot {
        color: var(--muted);
        text-align: center;
        font-size: 12px;
        margin-top: 24px;
      }

      .two-col {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px;
      }

      @media (max-width: 920px) {
        .grid {
          grid-template-columns: repeat(1, 1fr);
        }
        .two-col {
          grid-template-columns: 1fr;
        }
      }

      .col-12 {
        grid-column: span 12;
      }

      .col-8 {
        grid-column: span 8;
      }

      .col-6 {
        grid-column: span 6;
      }

      .col-4 {
        grid-column: span 4;
      }
    </style>
  </head>
  <body>
    <main class="container">
      <slot />
      <p class="foot">
        İstanbul → Riga karavan planı · Gerçek harita ve kamp planlaması modülü · Son güncelleme: 19 Temmuz 2026
      </p>
    </main>
  </body>
</html>
