---
interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="tr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta
      name="description"
      content={description ?? 'İstanbul-Letonya karavan yolculuğu planı ve gerçek zamanlı takip paneli'}
    />
    <title>{title}</title>
    <link rel="icon" href="/favicon.ico" />
    <!-- PWA / iOS app -->
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta name="theme-color" content="#07070b" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="Karavan" />
    <link rel="apple-touch-icon" href="/icons/apple-touch-icon.png" />
    <link rel="preconnect" href="https://unpkg.com" />
    <link rel="preconnect" href="https://www.google.com" />
    <link rel="preconnect" href="https://api.fontshare.com" crossorigin />
    <link rel="preconnect" href="https://cdn.fontshare.com" crossorigin />
    <link
      href="https://api.fontshare.com/v2/css?f[]=clash-display@600,700,500&f[]=general-sans@400,500,600,700&f[]=jetbrains-mono@500&display=swap"
      rel="stylesheet"
    />
    <script is:inline>
      // Tema seçimini FOUC olmadan uygula.
      (() => {
        try {
          const saved = localStorage.getItem('trip-theme');
          if (saved === 'light' || saved === 'dark') {
            document.documentElement.setAttribute('data-theme', saved);
          }
        } catch (_) {}
      })();
    </script>
    <style is:global>
      :root {
        color-scheme: dark;

        /* Yüzeyler */
        --bg: #07070b;
        --bg-2: #0d0d14;
        --panel: rgba(19, 19, 27, 0.62);
        --panel-solid: #14141d;
        --card-bg: rgba(255, 255, 255, 0.035);
        --text: #f6f6fb;
        --text-dim: #c9c9d6;
        --muted: #8a8a9e;
        --line: rgba(255, 255, 255, 0.08);
        --line-strong: rgba(255, 255, 255, 0.16);

        /* Marka spektrumu: gün doğumu → aurora */
        --c1: #ff9a3c;
        --c2: #ff4d6d;
        --c3: #a24bff;
        --c4: #33e0d0;
        --accent: #ff4d6d;
        --accent-2: #a24bff;
        --road: #ff9a3c;
        --road-soft: rgba(255, 154, 60, 0.16);

        --grad: linear-gradient(115deg, var(--c1), var(--c2) 38%, var(--c3) 70%, var(--c4));
        --grad-warm: linear-gradient(120deg, var(--c1), var(--c2));
        --grad-cool: linear-gradient(120deg, var(--c3), var(--c4));

        --ok: #38e08a;
        --warn: #ffc24b;
        --bad: #ff5470;

        --shadow: 0 24px 60px -22px rgba(0, 0, 0, 0.72);
        --shadow-sm: 0 10px 26px -14px rgba(0, 0, 0, 0.6);
        --radius: 24px;
        --radius-sm: 16px;

        --font-display: "Clash Display", "Space Grotesk", system-ui, sans-serif;
        --font-body: "General Sans", Inter, "Segoe UI", system-ui, sans-serif;
        --font-mono: "JetBrains Mono", ui-monospace, "SFMono-Regular", monospace;
      }

      :root[data-theme='light'] {
        color-scheme: light;
        --bg: #f3f3f8;
        --bg-2: #ffffff;
        --panel: rgba(255, 255, 255, 0.72);
        --panel-solid: #ffffff;
        --card-bg: rgba(18, 18, 40, 0.025);
        --text: #131320;
        --text-dim: #3a3a4d;
        --muted: #6a6a80;
        --line: rgba(15, 15, 40, 0.1);
        --line-strong: rgba(15, 15, 40, 0.18);
        --accent: #f5324f;
        --accent-2: #8a2fff;
        --road: #ef7212;
        --road-soft: rgba(239, 114, 18, 0.12);
        --ok: #12b268;
        --warn: #c07d06;
        --bad: #e03052;
        --shadow: 0 24px 60px -26px rgba(40, 30, 80, 0.26);
        --shadow-sm: 0 10px 24px -16px rgba(40, 30, 80, 0.22);
      }

      * {
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        color: var(--text);
        min-height: 100vh;
        position: relative;
        overflow-x: hidden;
        font-family: var(--font-body);
        font-size: 15.5px;
        line-height: 1.5;
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
        background: var(--bg);
      }

      /* Aurora arka plan (animasyonlu marka gradyanı) */
      body::before {
        content: "";
        position: fixed;
        inset: -25vh -15vw;
        z-index: -1;
        background:
          radial-gradient(38vw 38vw at 12% 2%, color-mix(in srgb, var(--c1) 32%, transparent), transparent 60%),
          radial-gradient(44vw 44vw at 88% 6%, color-mix(in srgb, var(--c3) 28%, transparent), transparent 62%),
          radial-gradient(48vw 40vw at 62% 100%, color-mix(in srgb, var(--c4) 24%, transparent), transparent 60%),
          radial-gradient(40vw 40vw at 2% 92%, color-mix(in srgb, var(--c2) 24%, transparent), transparent 60%);
        filter: blur(40px) saturate(1.15);
        animation: drift 26s ease-in-out infinite alternate;
        pointer-events: none;
      }

      :root[data-theme='light'] body::before {
        opacity: 0.55;
      }

      @keyframes drift {
        0% { transform: translate3d(0, 0, 0) scale(1); }
        100% { transform: translate3d(2.5%, -2%, 0) scale(1.08); }
      }

      @keyframes slide {
        to { background-position: 200% 0; }
      }

      @keyframes rise {
        from { opacity: 0; transform: translateY(18px); }
        to { opacity: 1; transform: none; }
      }

      a {
        color: var(--accent);
        text-decoration: none;
      }

      .container {
        width: min(1320px, 94vw);
        margin: 0 auto;
        padding: 16px 0 calc(72px + env(safe-area-inset-bottom, 0px));
      }

      .shell {
        position: relative;
        border: 1px solid var(--line);
        background: var(--panel);
        border-radius: var(--radius);
        padding: 26px;
        margin-bottom: 18px;
        box-shadow: var(--shadow);
        backdrop-filter: blur(22px) saturate(1.3);
        -webkit-backdrop-filter: blur(22px) saturate(1.3);
        animation: rise 0.62s cubic-bezier(0.2, 0.7, 0.2, 1) both;
      }

      /* Üst bar: sticky, cam, hap şeklinde */
      .topbar {
        position: sticky;
        top: calc(12px + env(safe-area-inset-top, 0px));
        z-index: 60;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        margin-bottom: 22px;
        padding: 8px 8px 8px 18px;
        border: 1px solid var(--line);
        border-radius: 999px;
        background: var(--panel);
        backdrop-filter: blur(18px) saturate(1.3);
        -webkit-backdrop-filter: blur(18px) saturate(1.3);
        box-shadow: var(--shadow-sm);
      }

      .brand {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        font-family: var(--font-display);
        font-weight: 600;
        font-size: 0.98rem;
        letter-spacing: 0.005em;
        color: var(--text);
        white-space: nowrap;
      }

      .brand__mark {
        font-size: 1.25rem;
        filter: drop-shadow(0 2px 6px color-mix(in srgb, var(--c1) 60%, transparent));
      }

      /* Ana navigasyon */
      .nav {
        display: flex;
        align-items: center;
        gap: 2px;
        margin: 0 auto;
      }

      .nav a {
        padding: 8px 14px;
        border-radius: 999px;
        font-size: 0.88rem;
        font-weight: 500;
        color: var(--muted);
        transition: color 160ms ease, background 160ms ease;
      }

      .nav a:hover {
        color: var(--text);
        background: var(--card-bg);
      }

      .topbar__actions {
        display: flex;
        align-items: center;
        gap: 8px;
      }

      .theme-toggle {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        border: 1px solid var(--line-strong);
        background: var(--card-bg);
        color: var(--text);
        border-radius: 999px;
        padding: 8px 15px;
        font-family: var(--font-body);
        font-size: 0.82rem;
        font-weight: 600;
        cursor: pointer;
        transition: border-color 180ms ease, background 180ms ease, transform 180ms ease;
      }

      .theme-toggle:hover {
        border-color: color-mix(in srgb, var(--accent) 60%, transparent);
        transform: translateY(-1px);
      }

      .nav-toggle {
        display: none;
        align-items: center;
        justify-content: center;
        width: 40px;
        height: 40px;
        font-size: 1.1rem;
        line-height: 1;
        border: 1px solid var(--line-strong);
        background: var(--card-bg);
        color: var(--text);
        border-radius: 999px;
        cursor: pointer;
        transition: border-color 160ms ease;
      }

      .nav-toggle:hover {
        border-color: color-mix(in srgb, var(--accent) 60%, transparent);
      }

      @media (max-width: 920px) {
        .nav {
          position: absolute;
          top: calc(100% + 8px);
          left: 0;
          right: 0;
          margin: 0;
          flex-direction: column;
          align-items: stretch;
          gap: 4px;
          padding: 10px;
          border: 1px solid var(--line);
          border-radius: 22px;
          background: var(--panel);
          backdrop-filter: blur(20px) saturate(1.3);
          -webkit-backdrop-filter: blur(20px) saturate(1.3);
          box-shadow: var(--shadow);
          opacity: 0;
          transform: translateY(-8px);
          pointer-events: none;
          transition: opacity 180ms ease, transform 180ms ease;
        }

        .nav.open {
          opacity: 1;
          transform: translateY(0);
          pointer-events: auto;
        }

        .nav a {
          padding: 12px 15px;
          border-radius: 13px;
          font-size: 0.95rem;
        }

        .nav a:hover {
          background: color-mix(in srgb, var(--accent) 12%, transparent);
        }

        .nav-toggle {
          display: inline-flex;
        }
      }

      h1, h2, h3, h4 {
        margin-top: 0;
        font-family: var(--font-display);
        font-weight: 600;
        letter-spacing: -0.02em;
        line-height: 1.06;
      }

      h1 {
        font-size: clamp(2rem, 4.4vw, 3.3rem);
      }

      h2 {
        font-size: clamp(1.5rem, 3vw, 2rem);
      }

      h3 {
        font-size: 1.28rem;
        margin-bottom: 10px;
        letter-spacing: -0.015em;
      }

      h4 {
        font-size: 1.02rem;
        letter-spacing: -0.01em;
      }

      .section-title {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 10px;
      }

      .subline {
        color: var(--muted);
        margin-top: 6px;
        margin-bottom: 16px;
      }

      /* ---- TAM GENİŞLİK IMMERSIVE HERO ---- */
      .hero-full {
        position: relative;
        width: 100vw;
        margin: -64px calc(50% - 50vw) 30px;
        min-height: min(90vh, 820px);
        display: flex;
        flex-direction: column;
        overflow: hidden;
        isolation: isolate;
        /* Hero her iki temada da koyu görsel üzerinde açık metin kullanır */
        --text: #ffffff;
        --text-dim: rgba(255, 255, 255, 0.84);
        --muted: rgba(255, 255, 255, 0.6);
        --line: rgba(255, 255, 255, 0.16);
        --line-strong: rgba(255, 255, 255, 0.32);
        --panel-solid: rgba(255, 255, 255, 0.14);
        --card-bg: rgba(255, 255, 255, 0.08);
      }

      .hero-full__bg {
        position: absolute;
        inset: 0;
        z-index: -2;
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: 72% center;
      }

      .hero-full__scrim {
        position: absolute;
        inset: 0;
        z-index: -1;
        background:
          linear-gradient(
            96deg,
            rgba(7, 8, 13, 0.95) 0%,
            rgba(7, 8, 13, 0.82) 34%,
            rgba(7, 8, 13, 0.34) 64%,
            rgba(7, 8, 13, 0.08) 100%
          ),
          linear-gradient(0deg, rgba(7, 8, 13, 0.96) 2%, transparent 32%),
          radial-gradient(80% 60% at 10% 20%, color-mix(in srgb, var(--c2) 22%, transparent), transparent 60%);
      }

      .hero-full__inner {
        width: min(1320px, 94vw);
        margin: 0 auto;
      }

      .hero-full > .hero-full__inner {
        flex: 1;
        display: flex;
        align-items: center;
      }

      .hero-full__content {
        max-width: 680px;
        padding: calc(128px + env(safe-area-inset-top, 0px)) 0 44px;
      }

      .hero-full h1 {
        color: #fff;
        font-size: clamp(2.4rem, 5.4vw, 4.3rem);
        line-height: 1.02;
        margin: 14px 0 0;
      }

      .hero-full__lead {
        color: rgba(255, 255, 255, 0.82);
        max-width: 52ch;
        margin: 18px 0 0;
        font-size: 1.06rem;
        line-height: 1.5;
      }

      .hero-metrics {
        display: flex;
        flex-wrap: wrap;
        gap: 14px 40px;
        margin-top: 30px;
      }

      .hero-metric {
        display: flex;
        flex-direction: column;
        gap: 3px;
      }

      .hero-metric__label {
        font-family: var(--font-mono);
        font-size: 0.64rem;
        text-transform: uppercase;
        letter-spacing: 0.2em;
        color: rgba(255, 255, 255, 0.58);
      }

      .hero-metric__value {
        font-family: var(--font-display);
        font-weight: 700;
        font-size: clamp(1.8rem, 3vw, 2.4rem);
        line-height: 1;
        color: #fff;
      }

      .hero-metric__unit {
        font-family: var(--font-mono);
        font-size: 0.74rem;
        color: rgba(255, 255, 255, 0.62);
      }

      /* Geri sayım = odak sayısı */
      .countdown-number {
        font-family: var(--font-display);
        font-weight: 700;
        line-height: 0.86;
        letter-spacing: -0.03em;
        background: var(--grad);
        background-size: 200% 100%;
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
        animation: slide 9s linear infinite;
      }

      .hero-metric--count .hero-metric__value.countdown-number {
        font-size: clamp(3.6rem, 6.5vw, 5.4rem);
      }

      .countdown-clock {
        font-variant-numeric: tabular-nums;
        color: #fff;
        font-weight: 500;
      }

      /* Segmentli canlı geri sayım (gün:saat:dk:sn) */
      .hero-metric--count {
        margin-top: 28px;
      }

      .count-tiles {
        display: flex;
        align-items: stretch;
        gap: 8px;
        margin-top: 8px;
        flex-wrap: wrap;
      }

      .ct {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-width: 76px;
        padding: 12px 12px 9px;
        border-radius: 18px;
        background: rgba(255, 255, 255, 0.09);
        border: 1px solid rgba(255, 255, 255, 0.2);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
      }

      .ct b {
        font-family: var(--font-display);
        font-weight: 700;
        font-size: clamp(1.9rem, 4.4vw, 3.1rem);
        line-height: 1;
        font-variant-numeric: tabular-nums;
        background: var(--grad);
        background-size: 200% 100%;
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
        animation: slide 9s linear infinite;
      }

      .ct span {
        margin-top: 5px;
        font-family: var(--font-mono);
        font-size: 0.6rem;
        text-transform: uppercase;
        letter-spacing: 0.18em;
        color: rgba(255, 255, 255, 0.6);
      }

      .count-tiles em {
        align-self: center;
        font-style: normal;
        font-family: var(--font-display);
        font-weight: 700;
        font-size: 1.7rem;
        color: rgba(255, 255, 255, 0.45);
        padding-bottom: 16px;
      }

      .ct--live {
        flex-direction: row;
        gap: 10px;
        padding: 16px 22px;
        font-family: var(--font-display);
        font-weight: 700;
        font-size: 1.5rem;
        color: #fff;
      }

      @media (max-width: 480px) {
        .ct {
          min-width: 62px;
          padding: 10px 8px 7px;
          border-radius: 14px;
        }
        .count-tiles em {
          display: none;
        }
      }

      /* ---- GÜNLÜK PLAN: TIMELINE ---- */
      .timeline {
        position: relative;
        display: flex;
        flex-direction: column;
        gap: 14px;
      }

      .timeline::before {
        content: "";
        position: absolute;
        left: 21px;
        top: 12px;
        bottom: 12px;
        width: 3px;
        border-radius: 999px;
        background: var(--grad);
        opacity: 0.4;
      }

      .t-item {
        position: relative;
        display: grid;
        grid-template-columns: 44px 1fr;
        gap: 16px;
        align-items: start;
        color: inherit;
      }

      .t-node {
        position: relative;
        z-index: 1;
        width: 44px;
        height: 44px;
        border-radius: 999px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: var(--font-display);
        font-weight: 700;
        font-size: 1.05rem;
        background: var(--grad-warm);
        color: #1a0e00;
        box-shadow: 0 8px 20px -8px color-mix(in srgb, var(--c1) 70%, transparent);
        margin-top: 4px;
        transition: transform 200ms cubic-bezier(0.2, 0.7, 0.2, 1);
      }

      .t-node--rest {
        background: var(--grad-cool);
        color: #fff;
      }

      .t-item:hover .t-node {
        transform: scale(1.12);
      }

      .t-card {
        border: 1px solid var(--line);
        border-radius: var(--radius-sm);
        background: var(--card-bg);
        backdrop-filter: blur(8px);
        -webkit-backdrop-filter: blur(8px);
        padding: 16px 18px;
        transition:
          transform 200ms cubic-bezier(0.2, 0.7, 0.2, 1),
          border-color 200ms ease,
          box-shadow 200ms ease;
      }

      .t-item:hover .t-card {
        transform: translateY(-3px);
        border-color: color-mix(in srgb, var(--accent) 45%, var(--line-strong));
        box-shadow: var(--shadow);
      }

      .t-head {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 10px;
        flex-wrap: wrap;
      }

      .t-date {
        font-family: var(--font-mono);
        font-size: 0.78rem;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--muted);
      }

      .t-route {
        font-family: var(--font-display);
        font-weight: 600;
        font-size: clamp(1.15rem, 2.4vw, 1.5rem);
        letter-spacing: -0.015em;
        color: var(--text);
        margin: 6px 0 12px;
      }

      .t-route em {
        font-style: normal;
        color: var(--road);
        padding: 0 4px;
      }

      .t-risk {
        margin: 12px 0 0;
        font-size: 0.9rem;
      }

      .t-foot {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 10px;
        flex-wrap: wrap;
        margin-top: 12px;
      }

      .t-go {
        color: var(--accent);
        font-weight: 600;
        font-size: 0.88rem;
        white-space: nowrap;
      }

      .hero-badges {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        margin-top: 32px;
      }

      .btn--glass {
        background: rgba(255, 255, 255, 0.1);
        border: 1px solid rgba(255, 255, 255, 0.26);
        color: #fff;
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
      }

      .btn--glass:hover {
        background: rgba(255, 255, 255, 0.18);
        border-color: rgba(255, 255, 255, 0.45);
      }

      .hero-full__stepper {
        padding: 16px 0 22px;
        border-top: 1px solid rgba(255, 255, 255, 0.12);
        background: linear-gradient(0deg, rgba(7, 8, 13, 0.55), transparent);
      }

      /* Gün sayfalarındaki stepper (shell içinde) */
      .hero-stepper {
        margin-top: 20px;
        padding-top: 18px;
        border-top: 1px solid var(--line);
      }

      @media (max-width: 720px) {
        .hero-full {
          margin-top: -56px;
          min-height: 88vh;
        }
        .hero-full__content {
          padding-top: 104px;
        }
        .hero-full__bg {
          object-position: 68% center;
        }
      }

      .grid {
        display: grid;
        grid-template-columns: repeat(12, 1fr);
        gap: 16px;
      }

      .card {
        position: relative;
        padding: 18px;
        border: 1px solid var(--line);
        border-radius: var(--radius-sm);
        background: var(--card-bg);
        backdrop-filter: blur(8px);
        -webkit-backdrop-filter: blur(8px);
        transition:
          transform 200ms cubic-bezier(0.2, 0.7, 0.2, 1),
          border-color 200ms ease,
          box-shadow 200ms ease;
      }

      .card:hover {
        transform: translateY(-4px);
        border-color: color-mix(in srgb, var(--accent) 45%, var(--line-strong));
        box-shadow: var(--shadow);
      }

      /* Aşama numarası rozeti */
      .stage-badge {
        position: absolute;
        top: 14px;
        right: 14px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 28px;
        height: 24px;
        padding: 0 9px;
        border-radius: 999px;
        font-family: var(--font-mono);
        font-size: 0.7rem;
        font-weight: 500;
        letter-spacing: 0.02em;
        color: #1a0e00;
        background: var(--grad-warm);
      }

      .muted {
        color: var(--muted);
      }

      .tag-row {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
      }

      details {
        margin: 10px 0 0;
        border: 1px solid var(--line);
        border-radius: 12px;
        padding: 12px 14px;
        background: var(--card-bg);
        transition: border-color 180ms ease;
      }

      details[open] {
        border-color: color-mix(in srgb, var(--accent) 30%, var(--line));
      }

      summary {
        cursor: pointer;
        color: var(--text);
        font-weight: 600;
        margin-bottom: 8px;
        list-style: none;
      }

      summary::-webkit-details-marker {
        display: none;
      }

      summary::before {
        content: "＋";
        display: inline-block;
        width: 1.1em;
        color: var(--accent);
        font-weight: 700;
      }

      details[open] summary::before {
        content: "－";
      }

      details p {
        margin: 6px 0;
      }

      .tag {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        border: 1px solid var(--line);
        border-radius: 999px;
        padding: 5px 11px;
        font-size: 12px;
        font-weight: 500;
        color: var(--text-dim);
        background: var(--card-bg);
      }

      .tag--road {
        color: var(--road);
        background: var(--road-soft);
        border-color: color-mix(in srgb, var(--road) 30%, transparent);
        font-weight: 600;
      }

      .pill {
        border-radius: 999px;
        padding: 7px 13px;
        border: 1px solid var(--line);
        background: var(--card-bg);
        color: var(--text-dim);
        font-size: 0.82rem;
      }

      /* Risk seviyesi rozetleri */
      .lvl {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        border-radius: 999px;
        padding: 5px 11px;
        font-size: 12px;
        font-weight: 600;
      }

      .lvl::before {
        content: "";
        width: 7px;
        height: 7px;
        border-radius: 999px;
        background: currentColor;
        box-shadow: 0 0 8px currentColor;
      }

      .lvl--ok {
        color: var(--ok);
        background: color-mix(in srgb, var(--ok) 13%, transparent);
      }

      .lvl--warn {
        color: var(--warn);
        background: color-mix(in srgb, var(--warn) 15%, transparent);
      }

      .lvl--bad {
        color: var(--bad);
        background: color-mix(in srgb, var(--bad) 14%, transparent);
      }

      .day-link {
        display: flex;
        justify-content: space-between;
        gap: 10px;
        align-items: baseline;
        margin-bottom: 10px;
      }

      .day-link strong {
        color: var(--text);
        font-family: var(--font-display);
        font-weight: 600;
        font-size: 1.05rem;
      }

      .map-frame,
      .route-map {
        width: 100%;
        min-height: 360px;
        border: 1px solid var(--line);
        border-radius: var(--radius-sm);
      }

      .btn {
        position: relative;
        border: 1px solid var(--line-strong);
        background: var(--card-bg);
        color: var(--text);
        border-radius: 12px;
        padding: 11px 17px;
        font-family: var(--font-body);
        font-weight: 600;
        font-size: 0.92rem;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        transition:
          transform 160ms cubic-bezier(0.2, 0.7, 0.2, 1),
          background 160ms ease,
          border-color 160ms ease,
          filter 160ms ease;
        cursor: pointer;
      }

      .btn:hover {
        transform: translateY(-2px);
        border-color: color-mix(in srgb, var(--accent) 55%, transparent);
        background: color-mix(in srgb, var(--accent) 10%, transparent);
      }

      .btn:focus-visible {
        outline: 2px solid var(--accent);
        outline-offset: 3px;
      }

      .btn--ghost {
        border-color: var(--line);
        background: transparent;
        color: var(--muted);
        font-weight: 500;
      }

      .btn--ghost:hover {
        color: var(--text);
        background: var(--card-bg);
        border-color: var(--line-strong);
      }

      .btn--primary {
        background: var(--grad-cool);
        border: none;
        color: #fff;
        box-shadow: 0 10px 26px -10px color-mix(in srgb, var(--accent-2) 70%, transparent);
      }

      .btn--primary:hover {
        filter: brightness(1.08);
        border: none;
      }

      /* Ana yol butonu (bugünün güzergâhı) */
      .btn--road {
        background: var(--grad-warm);
        border: none;
        color: #1a0e00;
        font-weight: 700;
        box-shadow: 0 10px 26px -10px color-mix(in srgb, var(--c1) 65%, transparent);
      }

      .btn--road:hover {
        filter: brightness(1.06);
        border: none;
      }

      .metric-row {
        margin-top: 14px;
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
      }

      .metric {
        border: 1px solid var(--line);
        border-radius: 14px;
        padding: 12px 14px;
        min-width: 128px;
        background: var(--card-bg);
      }

      .metric b {
        display: block;
        margin-top: 3px;
        font-family: var(--font-display);
        font-weight: 600;
        font-size: 1.05rem;
      }

      .metric span {
        color: var(--muted);
        font-size: 11.5px;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        font-family: var(--font-mono);
      }

      .route-list {
        margin: 10px 0 0;
        padding-left: 18px;
      }

      .route-list li + li {
        margin-top: 7px;
      }

      .task-check-wrap {
        display: flex;
        flex-direction: column;
        gap: 8px;
      }

      .task-check-row {
        display: grid;
        grid-template-columns: 20px 1fr;
        gap: 12px;
        align-items: center;
      }

      .task-check-row p {
        margin: 0;
      }

      .task-check-row input[type="checkbox"] {
        width: 18px;
        height: 18px;
        accent-color: var(--accent);
        cursor: pointer;
      }

      .task-check-row .due {
        color: var(--muted);
        font-size: 0.75rem;
      }

      .badges {
        display: flex;
        align-items: center;
        gap: 8px;
        flex-wrap: wrap;
      }

      .two-col {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 14px;
      }

      .foot {
        color: var(--muted);
        text-align: center;
        font-size: 12px;
        font-family: var(--font-mono);
        margin-top: 30px;
      }

      .col-12 { grid-column: span 12; }
      .col-8 { grid-column: span 8; }
      .col-6 { grid-column: span 6; }
      .col-4 { grid-column: span 4; }

      .progress-wrap {
        margin-top: 14px;
      }

      .progress {
        width: 100%;
        height: 9px;
        border-radius: 999px;
        border: 1px solid var(--line);
        background: color-mix(in srgb, var(--text) 7%, transparent);
        overflow: hidden;
      }

      .progress > span {
        display: block;
        height: 100%;
        background: var(--grad-warm);
        transition: width 400ms cubic-bezier(0.2, 0.7, 0.2, 1);
      }

      .tiny-note {
        color: var(--muted);
        font-size: 12px;
      }

      ::selection {
        background: color-mix(in srgb, var(--accent) 32%, transparent);
        color: var(--text);
      }

      @media (max-width: 900px) {
        .grid,
        .two-col {
          grid-template-columns: 1fr;
        }

        .col-8, .col-6, .col-4 {
          grid-column: span 12;
        }
      }

      @media (max-width: 820px) {
        .hero-top {
          grid-template-columns: 1fr;
          gap: 18px;
        }

        .hero-image {
          min-height: 160px;
          order: -1;
        }

        .hero {
          padding: 24px;
        }
      }

      @media (max-width: 640px) {
        .hero-badges {
          justify-content: stretch;
        }

        .hero-badges .btn {
          flex: 1 1 140px;
          justify-content: center;
        }

        .map-frame,
        .route-map {
          min-height: 300px;
        }

        .topbar .brand__route {
          display: none;
        }
      }

      @media (prefers-reduced-motion: reduce) {
        *,
        body::before,
        .hero::after,
        .countdown-number {
          animation: none !important;
          transition: none !important;
        }

        html {
          scroll-behavior: auto;
        }
      }

      /* ---- Brifing bölümleri ---- */
      .sec-head {
        margin-bottom: 20px;
      }

      .eyebrow {
        display: inline-block;
        font-family: var(--font-mono);
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 0.24em;
        color: var(--accent);
        margin-bottom: 8px;
      }

      .sec-head h2 {
        margin: 0;
      }

      .sec-head .subline {
        margin-bottom: 0;
      }

      .flag {
        font-size: 1.7rem;
        line-height: 1;
        filter: drop-shadow(0 3px 8px rgba(0, 0, 0, 0.35));
      }

      .card-head {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 6px;
      }

      .card-head h4 {
        margin: 0;
        font-size: 1.2rem;
      }

      .stat-row {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
        margin: 12px 0 14px;
      }

      .stat {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-family: var(--font-mono);
        font-size: 11px;
        color: var(--text-dim);
        background: var(--card-bg);
        border: 1px solid var(--line);
        border-radius: 8px;
        padding: 5px 9px;
      }

      .callout {
        position: relative;
        margin-top: 14px;
        padding: 12px 14px 12px 18px;
        border-radius: 12px;
        background: color-mix(in srgb, var(--road) 8%, transparent);
        border: 1px solid color-mix(in srgb, var(--road) 22%, transparent);
      }

      .callout::before {
        content: "";
        position: absolute;
        left: 0;
        top: 10px;
        bottom: 10px;
        width: 3px;
        border-radius: 999px;
        background: var(--grad-warm);
      }

      .callout__label {
        display: block;
        font-family: var(--font-mono);
        font-size: 10px;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: var(--road);
        font-weight: 600;
        margin-bottom: 3px;
      }

      .callout p {
        margin: 0;
      }

      .net-note {
        margin-top: 14px;
        padding: 11px 14px;
        border-radius: 12px;
        border: 1px solid var(--line-strong);
        background: var(--card-bg);
        font-size: 0.92rem;
      }

      .net-note strong {
        color: var(--accent);
        font-weight: 600;
      }

      .hl-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
        margin: 4px 0 0;
      }

      .strat-list {
        list-style: none;
        margin: 12px 0 0;
        padding: 0;
        display: flex;
        flex-direction: column;
        gap: 9px;
      }

      .strat-list li {
        position: relative;
        padding-left: 26px;
        line-height: 1.45;
      }

      .strat-list li::before {
        content: "→";
        position: absolute;
        left: 0;
        top: 0;
        color: var(--accent);
        font-weight: 700;
      }

      .camp-split {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 10px;
        margin: 8px 0;
      }

      .camp-opt {
        border: 1px solid var(--line);
        border-radius: 12px;
        padding: 11px 13px;
        background: var(--card-bg);
      }

      .camp-opt__tag {
        font-family: var(--font-mono);
        font-size: 10px;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        margin-bottom: 5px;
        display: block;
      }

      .camp-opt--primary .camp-opt__tag { color: var(--ok); }
      .camp-opt--alt .camp-opt__tag { color: var(--accent-2); }

      @media (max-width: 560px) {
        .camp-split {
          grid-template-columns: 1fr;
        }
      }

      /* Yazdırma / PDF brifing çıktısı */
      @media print {
        :root {
          --bg: #fff;
          --panel: #fff;
          --card-bg: #fff;
          --text: #111;
          --text-dim: #222;
          --muted: #444;
          --line: #ccc;
          --line-strong: #bbb;
        }

        body { background: #fff; color: #000; }
        body::before { display: none; }
        .container { width: 100%; padding: 0; }

        .topbar,
        .theme-toggle,
        .hero-badges,
        .btn,
        iframe,
        .route-map,
        .map-frame {
          display: none !important;
        }

        .shell, .card {
          break-inside: avoid;
          box-shadow: none;
          border: 1px solid #ccc;
          backdrop-filter: none;
          animation: none;
        }

        .countdown-number,
        .stage-badge {
          -webkit-text-fill-color: #000;
          color: #000;
          background: none;
        }

        a { color: #000; }
      }
    </style>
  </head>
  <body>
    <main class="container">
      <header class="topbar">
        <a class="brand" href="/">
          <span class="brand__mark">🚐</span>
          <span class="brand__name">KARAVAN BRIFING</span>
        </a>
        <nav class="nav" id="nav">
          <a href="/#hava">Hava</a>
          <a href="/#ulkeler">Ülkeler</a>
          <a href="/#plan">Günlük Plan</a>
          <a href="/#harita">Harita</a>
          <a href="/#check">Hazırlık</a>
        </nav>
        <div class="topbar__actions">
          <button class="theme-toggle" id="theme-toggle" type="button" aria-label="Tema değiştir">
            <span id="theme-icon">🌙</span>
            <span id="theme-text">Koyu</span>
          </button>
          <button class="nav-toggle" id="nav-toggle" type="button" aria-label="Menüyü aç/kapat" aria-expanded="false">☰</button>
        </div>
      </header>
      <slot />
      <p class="foot">
        İstanbul → Riga karavan planı · Gerçek harita ve kamp planlaması modülü · Son güncelleme: 19 Temmuz 2026
      </p>
    </main>
    <script is:inline>
      (() => {
        const root = document.documentElement;
        const btn = document.getElementById('theme-toggle');
        const icon = document.getElementById('theme-icon');
        const text = document.getElementById('theme-text');
        if (!btn) return;

        // Varsayılan koyu tema (CSS'te data-theme yoksa koyu render edilir).
        const effective = () => root.getAttribute('data-theme') || 'dark';

        const paint = (mode) => {
          const light = mode === 'light';
          icon.textContent = light ? '☀️' : '🌙';
          text.textContent = light ? 'Açık' : 'Koyu';
        };

        paint(effective());

        btn.addEventListener('click', () => {
          const next = effective() === 'light' ? 'dark' : 'light';
          root.setAttribute('data-theme', next);
          try {
            localStorage.setItem('trip-theme', next);
          } catch (_) {}
          paint(next);
        });
      })();

      // Mobil navigasyon aç/kapat
      (() => {
        const toggle = document.getElementById('nav-toggle');
        const nav = document.getElementById('nav');
        if (!toggle || !nav) return;

        const setOpen = (open) => {
          nav.classList.toggle('open', open);
          toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
          toggle.textContent = open ? '✕' : '☰';
        };

        toggle.addEventListener('click', (e) => {
          e.stopPropagation();
          setOpen(!nav.classList.contains('open'));
        });

        // Bir bağlantıya tıklanınca veya dışarı tıklanınca kapat
        nav.addEventListener('click', (e) => {
          if (e.target.tagName === 'A') setOpen(false);
        });
        document.addEventListener('click', (e) => {
          if (nav.classList.contains('open') && !nav.contains(e.target) && e.target !== toggle) {
            setOpen(false);
          }
        });
      })();
    </script>
  </body>
</html>
