---
interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="tr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content={description ?? 'İstanbul-Letonya karavan yolculuğu planı ve gerçek zamanlı takip paneli'}
    />
    <title>{title}</title>
    <link rel="icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://unpkg.com" />
    <link rel="preconnect" href="https://www.google.com" />
    <style is:global>
      :root {
        --bg: #050b16;
        --panel: rgba(14, 24, 46, 0.84);
        --text: #e9f1ff;
        --muted: #9eb2d1;
        --line: rgba(120, 150, 210, 0.33);
        --accent: #67a6ff;
        --ok: #39d98a;
        --warn: #ffcf66;
        --bad: #ff7088;
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        color: var(--text);
        min-height: 100vh;
        font-family:
          Inter,
          "Segoe UI",
          Roboto,
          Helvetica,
          Arial,
          sans-serif;
        background:
          radial-gradient(circle at 0% 0%, rgba(103, 166, 255, 0.16), transparent 36%),
          radial-gradient(circle at 85% 0%, rgba(89, 224, 255, 0.08), transparent 30%),
          radial-gradient(circle at 20% 100%, rgba(60, 110, 255, 0.1), transparent 36%),
          var(--bg);
      }

      a {
        color: var(--accent);
        text-decoration: none;
      }

      .container {
        width: min(1180px, 95vw);
        margin: 0 auto;
        padding: 28px 0 62px;
      }

      .shell {
        border: 1px solid var(--line);
        background: var(--panel);
        border-radius: 20px;
        padding: 20px;
        margin-bottom: 16px;
        box-shadow: 0 10px 38px rgba(0, 0, 0, 0.28);
        backdrop-filter: blur(2px);
      }

      h1,
      h2,
      h3,
      h4 {
        margin-top: 0;
      }

      h1 {
        line-height: 1.2;
        font-size: clamp(1.5rem, 2.6vw, 2rem);
      }

      h2 {
        line-height: 1.25;
        font-size: 1.4rem;
      }

      h3 {
        line-height: 1.2;
        font-size: 1.1rem;
        margin-bottom: 10px;
      }

      h4 {
        line-height: 1.3;
        font-size: 1rem;
      }

      .section-title {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 10px;
      }

      .subline {
        color: var(--muted);
        margin-top: 4px;
        margin-bottom: 14px;
      }

      .hero {
        position: relative;
        overflow: hidden;
        background:
          linear-gradient(
            125deg,
            rgba(103, 166, 255, 0.14) 0%,
            rgba(9, 20, 39, 0.02) 46%,
            rgba(89, 224, 255, 0.1) 100%
          ),
          rgba(10, 20, 41, 0.32);
      }

      .hero p {
        color: var(--muted);
        margin-top: 8px;
        max-width: 74ch;
      }

      .hero-image {
        margin-top: 12px;
        border-radius: 14px;
        width: 100%;
        min-height: 190px;
        object-fit: cover;
        border: 1px solid rgba(120, 150, 210, 0.45);
        background: linear-gradient(130deg, rgba(103, 166, 255, 0.16), rgba(89, 224, 255, 0.08));
      }

      .hero-badges {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin-top: 14px;
      }

      .grid {
        display: grid;
        grid-template-columns: repeat(12, 1fr);
        gap: 14px;
      }

      .card {
        padding: 14px;
        border: 1px solid var(--line);
        border-radius: 15px;
        background: rgba(8, 16, 32, 0.45);
        transition:
          transform 140ms ease,
          border-color 180ms ease,
          box-shadow 180ms ease;
      }

      .card:hover {
        transform: translateY(-2px);
        border-color: rgba(118, 186, 255, 0.6);
        box-shadow: 0 10px 24px rgba(5, 8, 16, 0.34);
      }

      .muted {
        color: var(--muted);
      }

      .tag-row {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
      }

      .tag {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        border: 1px solid var(--line);
        border-radius: 999px;
        padding: 5px 10px;
        font-size: 12px;
        color: #c6dcff;
        background: rgba(103, 166, 255, 0.12);
      }

      .pill {
        border-radius: 999px;
        padding: 8px 12px;
        border: 1px solid rgba(118, 175, 255, 0.42);
        background: rgba(103, 166, 255, 0.07);
        color: #dfecff;
        font-size: 0.85rem;
      }

      .day-link {
        display: flex;
        justify-content: space-between;
        gap: 10px;
        align-items: baseline;
        margin-bottom: 8px;
      }

      .day-link strong {
        color: #fff;
      }

      .map-frame,
      .route-map {
        width: 100%;
        min-height: 360px;
        border: 1px solid var(--line);
        border-radius: 12px;
      }

      .btn {
        border: 1px solid rgba(103, 166, 255, 0.5);
        background: linear-gradient(180deg, rgba(103, 166, 255, 0.18), rgba(103, 166, 255, 0.12));
        color: #eaf2ff;
        border-radius: 10px;
        padding: 9px 12px;
        font-weight: 600;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        transition:
          transform 120ms ease,
          background 120ms ease,
          border-color 120ms ease;
        cursor: pointer;
      }

      .btn:hover {
        border-color: #67a6ff;
        transform: translateY(-1px);
        background: linear-gradient(180deg, rgba(103, 166, 255, 0.3), rgba(103, 166, 255, 0.2));
      }

      .btn:focus-visible {
        outline: 2px solid rgba(103, 166, 255, 0.75);
        outline-offset: 2px;
      }

      .btn--ghost {
        border-color: rgba(120, 150, 210, 0.35);
        background: rgba(11, 19, 40, 0.35);
        color: #cfdef9;
        font-weight: 500;
      }

      .btn--ghost:hover {
        background: rgba(103, 166, 255, 0.12);
      }

      .btn--primary {
        background: linear-gradient(150deg, #3d87ff, #6ca5ff);
        border: none;
        color: white;
      }

      .metric-row {
        margin-top: 12px;
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
      }

      .metric {
        border: 1px solid rgba(120, 150, 210, 0.35);
        border-radius: 12px;
        padding: 10px 12px;
        min-width: 120px;
      }

      .metric b {
        display: block;
        margin-top: 2px;
      }

      .metric span {
        color: var(--muted);
        font-size: 12px;
      }

      .route-list {
        margin: 8px 0 0;
        padding-left: 18px;
      }

      .route-list li + li {
        margin-top: 6px;
      }

      .task-check-wrap {
        display: flex;
        flex-direction: column;
        gap: 8px;
      }

      .task-check-row {
        display: grid;
        grid-template-columns: 20px 1fr;
        gap: 10px;
        align-items: center;
      }

      .task-check-row p {
        margin: 0;
      }

      .task-check-row .due {
        color: #aebfe0;
        font-size: 0.75rem;
      }

      .badges {
        display: flex;
        align-items: center;
        gap: 8px;
        flex-wrap: wrap;
      }

      .two-col {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px;
      }

      .foot {
        color: var(--muted);
        text-align: center;
        font-size: 12px;
        margin-top: 24px;
      }

      .col-12 {
        grid-column: span 12;
      }

      .col-8 {
        grid-column: span 8;
      }

      .col-6 {
        grid-column: span 6;
      }

      .col-4 {
        grid-column: span 4;
      }

      .progress-wrap {
        margin-top: 12px;
      }

      .progress {
        width: 100%;
        height: 8px;
        border-radius: 999px;
        border: 1px solid rgba(120, 150, 210, 0.4);
        background: rgba(17, 26, 45, 0.9);
        overflow: hidden;
      }

      .progress > span {
        display: block;
        height: 100%;
        background: linear-gradient(90deg, #3d87ff, #5fb4ff);
        transition: width 180ms ease;
      }

      .tiny-note {
        color: #b4c6ea;
        font-size: 12px;
      }

      @media (max-width: 920px) {
        .grid,
        .two-col {
          grid-template-columns: 1fr;
        }
      }

      @media (max-width: 640px) {
        .hero-badges {
          justify-content: stretch;
        }

        .hero-badges .btn {
          width: 100%;
          justify-content: center;
        }

        .map-frame,
        .route-map {
          min-height: 300px;
        }
      }
    </style>
  </head>
  <body>
    <main class="container">
      <slot />
      <p class="foot">
        İstanbul → Riga karavan planı · Gerçek harita ve kamp planlaması modülü · Son güncelleme: 19 Temmuz 2026
      </p>
    </main>
  </body>
</html>
