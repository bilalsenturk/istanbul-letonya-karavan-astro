---
import MainLayout from '../layouts/MainLayout.astro';
import RouteMap from '../components/RouteMap.astro';
import RouteStepper from '../components/RouteStepper.astro';
import WeatherStrip from '../components/WeatherStrip.astro';
import { tripData } from '../data/tripData';

const departureDate = new Date(tripData.departureAt);
const today = new Date();
const daysUntilDeparture = Math.max(0, Math.ceil((departureDate.getTime() - today.getTime()) / 86400000));
const daySpan = tripData.days.length;
const mapStops = tripData.stops.map((stop) => ({ name: stop.name, lat: stop.lat, lng: stop.lng }));
const stepperStops = tripData.stops.map((stop) => ({ name: stop.name, country: stop.country }));
const weatherStops = tripData.stops.map((stop) => ({
  name: stop.name,
  country: stop.country,
  lat: stop.lat,
  lng: stop.lng,
}));
const countryChain = tripData.countryGuides.map((country) => country.country).join(' → ');

// Günün zorluk seviyesini mesafe/süreye göre kabaca sınıflandır.
function dayLevel(day: (typeof tripData.days)[number]): 'ok' | 'warn' | 'bad' {
  if (/dinlenme|sürüş yok/i.test(day.distanceKm + day.duration)) return 'ok';
  const km = parseInt(day.distanceKm.replace(/[^\d]/g, '').slice(0, 3), 10) || 0;
  if (km >= 550) return 'bad';
  if (km >= 440) return 'warn';
  return 'ok';
}
const levelText = { ok: 'Rahat gün', warn: 'Dikkatli', bad: 'Uzun etap' };

// Ülke bayrakları
const countryFlags: Record<string, string> = {
  'Türkiye': '🇹🇷',
  'Bulgaristan': '🇧🇬',
  'Romanya': '🇷🇴',
  'Macaristan': '🇭🇺',
  'Slovakya': '🇸🇰',
  'Çekya': '🇨🇿',
  'Polonya': '🇵🇱',
  'Litvanya': '🇱🇹',
  'Letonya': '🇱🇻',
};

// "Nüfus: 85 milyon" → "85 milyon"
const stripLabel = (s: string): string => (s.includes(': ') ? s.slice(s.indexOf(': ') + 2) : s);
---

<MainLayout
  title="Kuzey — Letonya Yolculuğu"
  description="İstanbul'dan Riga'ya karavan rotası: günlük plan, canlı hava ve konum, kamp ve hazırlık listesi."
>
  <section class="hero-full">
    <img
      class="hero-full__bg"
      src="/assets/passat-adria-karavan.png"
      alt="Passat + Adria karavan Riga yolunda"
      fetchpriority="high"
    />
    <div class="hero-full__scrim"></div>
    <div class="hero-full__inner">
      <div class="hero-full__content">
        <span class="eyebrow">İstanbul → Riga · {tripData.totalKm.toLocaleString('tr-TR')} km · {tripData.countryGuides.length} ülke</span>
        <h1>Letonya Yolculuğu</h1>
        <p class="hero-full__lead">
          {daySpan} günlük karavan rotası, günlük plan, canlı trafik, kamp ve ekipman kontrol listesi — tek ekranda.
        </p>
        <div class="hero-metric hero-metric--count">
          <span class="hero-metric__label">Yola çıkmaya kalan</span>
          <div class="count-tiles" id="count-tiles" aria-live="polite">
            <div class="ct"><b id="ct-d">{daysUntilDeparture}</b><span>gün</span></div>
            <em>:</em>
            <div class="ct"><b id="ct-h">–</b><span>saat</span></div>
            <em>:</em>
            <div class="ct"><b id="ct-m">–</b><span>dk</span></div>
            <em>:</em>
            <div class="ct"><b id="ct-s">–</b><span>sn</span></div>
          </div>
        </div>
        <div class="hero-metrics">
          <div class="hero-metric">
            <span class="hero-metric__label">Toplam mesafe</span>
            <span class="hero-metric__value">{tripData.totalKm.toLocaleString('tr-TR')}</span>
            <span class="hero-metric__unit">kilometre</span>
          </div>
          <div class="hero-metric">
            <span class="hero-metric__label">Yakıt bütçesi</span>
            <span class="hero-metric__value">{tripData.totalBudget.fuel}</span>
            <span class="hero-metric__unit">tahmini</span>
          </div>
          <div class="hero-metric">
            <span class="hero-metric__label">Rota</span>
            <span class="hero-metric__value">{daySpan} gün</span>
            <span class="hero-metric__unit">{tripData.stops.length} durak · {tripData.countryGuides.length} ülke</span>
          </div>
        </div>
        <div class="hero-badges">
          <a class="btn btn--road" href="/day/istanbul-sofya">Bugünün Güzergâhı</a>
          <a class="btn btn--primary" href="#plan">Günlük Plan</a>
          <a class="btn btn--glass" href="#ulkeler">Ülke Brifingi</a>
          <a class="btn btn--glass" href="#harita">Canlı Harita</a>
        </div>
      </div>
    </div>
    <div class="hero-full__stepper">
      <div class="hero-full__inner">
        <RouteStepper stops={stepperStops} activeIndex={-1} />
      </div>
    </div>
  </section>

  <section class="grid">
    <article class="card col-4">
      <h3>Yolculuk Özeti</h3>
      <p><strong>Planlanan çıkış:</strong> {new Date(tripData.departureAt).toLocaleDateString('tr-TR', { year: 'numeric', month: 'long', day: 'numeric' })}</p>
      <p><strong>Süre:</strong> {daySpan} gün · {tripData.stops.length} durak</p>
      <p><strong>Pratik bütçe hedefi:</strong> {tripData.totalBudget.total}</p>
    </article>

    <article class="card col-4">
      <div class="section-title">
        <h3>Karavan Nerede?</h3>
        <span class="lvl lvl--ok" id="live-badge" hidden>Canlı</span>
      </div>
      <p id="location-status" class="muted">Kuzey uygulamasından canlı konum bekleniyor…</p>
      <p><strong>Riga'ya kalan:</strong> <span id="remaining-distance">—</span></p>
      <p><strong>En yakın durak:</strong> <span id="nearest-stop">—</span></p>
      <p><strong>Hız:</strong> <span id="live-speed">—</span></p>
      <p class="tiny-note" id="live-updated"></p>
      <span id="target-city" hidden>Sofya</span>
      <span id="remaining-time" hidden></span>
    </article>

    <article class="card col-4">
      <h3>Hazırlık Durumu</h3>
      <p><strong>Çekim:</strong> {tripData.vehicle.towing}</p>
      <p><strong>Yükleme:</strong> Ağır eşyalar dingile yakın, hassas eşyalar sabitlenmiş.</p>
      <div class="progress-wrap">
        <div class="tag-row">
          <span class="tag">Kontrol listesi</span>
          <span class="tiny-note" id="task-status">0 / {tripData.checklist.length}</span>
        </div>
        <div class="progress" aria-label="Hazırlık ilerleme çubuğu">
          <span id="task-progress" style="width: 0%"></span>
        </div>
      </div>
    </article>
  </section>

  <section id="check" class="shell">
    <div class="section-title">
      <div>
        <h3>Yola Çıkmadan Önce Hazırlık Kontrol Listesi</h3>
        <p class="subline">İşaretlediklerin bu tarayıcıda saklanır.</p>
      </div>
      <a class="btn btn--ghost" href="#plan">Plan Modülüne Git</a>
    </div>
    <div class="card task-check-wrap">
      {tripData.checklist.map((item) => (
        <label class="task-check-row">
          <input type="checkbox" class="task-check" data-task={item.id} />
          <div>
            <p><strong>{item.due}</strong> — {item.task}</p>
          </div>
        </label>
      ))}
    </div>

    <div class="grid" style="margin-top: 12px;">
      <article class="card col-12">
        <h4>Hedeflenen 10 kritik aksiyon</h4>
        <ol class="route-list">
          <li>Deutsche Schule Riga'ya 2026/27 başlangıç teyidi</li>
          <li>Litonya'ya hareket öncesi son teknik ve sigorta kontrolü</li>
          <li>Karavan elektrik sorunlarının yazılı çözüm teyidi</li>
          <li>PMLP randevusu, adres ve şirket sürecini eşzamanlama</li>
          <li>Liman ve kamp rezervasyon alternatifleri (Sofya/Bükreş/Budapeşte)</li>
          <li>Vinyet + otoyol ücret güncellemesi</li>
          <li>Yedek plan: gecikme ve mola saatleri</li>
          <li>Riga'ya girişte kamp ve internet/elektrik doğrulama</li>
          <li>Okul ve buz pateni süreç belgelerinin yedek kopyası</li>
          <li>Finans tamponu ve kart limitleri kontrolü</li>
        </ol>
      </article>
    </div>
  </section>

  <section id="hava" class="shell">
    <div class="sec-head">
      <span class="eyebrow">Canlı · Open-Meteo</span>
      <h2>Duraklarda hava durumu</h2>
      <p class="subline">Her durağın şu anki sıcaklığı ve koşulu. Yağış olan duraklar vurgulanır; sayfa her açıldığında güncellenir.</p>
    </div>
    <WeatherStrip stops={weatherStops} />
  </section>

  <section id="harita" class="shell">
    <h3>Rota Haritası</h3>
    <RouteMap
      title="İstanbul → Riga Tam Rota"
      routeStops={mapStops}
      activeFrom="İstanbul"
      activeTo="Riga"
      height="430px"
      />
  </section>

  <section class="shell" id="ulkeler">
    <div class="sec-head section-title">
      <div>
        <span class="eyebrow">Ülke Brifingi · {tripData.countryGuides.length} ülke</span>
        <h2>Yol boyunca geçilecek ülkeler</h2>
        <p class="subline">Her ülke için künye, öne çıkan duraklar, alışveriş/mola stratejisi ve yol notu.</p>
      </div>
      <a class="btn btn--ghost" href="#plan">Gün planına geç</a>
    </div>
    <div class="grid">
      {tripData.countryGuides.map((country) => (
        <article class="card col-6">
          <div class="card-head">
            <span class="flag">{countryFlags[country.country] ?? '🏳️'}</span>
            <h4>{country.country}</h4>
          </div>
          <div class="stat-row">
            <span class="stat">👥 {stripLabel(country.population)}</span>
            <span class="stat">💬 {stripLabel(country.language)}</span>
            <span class="stat">💱 {stripLabel(country.currency)}</span>
            <span class="stat">🚗 {stripLabel(country.traffic)}</span>
          </div>
          <p>{country.profile}</p>
          <div class="hl-tags">
            {country.highlights.map((item) => <span class="tag tag--road">{item}</span>)}
          </div>
          <div class="callout">
            <span class="callout__label">Alışveriş / Mola tercihi</span>
            <p>{country.shopping}</p>
          </div>
          <details>
            <summary>Operasyon notları</summary>
            <p class="muted">{stripLabel(country.religion)} · {stripLabel(country.traffic)}</p>
            {country.shoppingAdvice ? <p class="muted">{country.shoppingAdvice}</p> : null}
            <p><strong>Net karar:</strong> {country.highlightsAdvice}</p>
            <p class="muted"><strong>Yol notu:</strong> {country.roadNote}</p>
          </details>
        </article>
      ))}
    </div>
  </section>

  <section class="shell" id="etaplar">
    <div class="sec-head section-title">
      <div>
        <span class="eyebrow">Etap Analizi · {tripData.segmentGuides.length} etap</span>
        <h2>Hangi gün neye odaklanmalı</h2>
        <p class="subline">Her etabın yol üstü görülecekleri ve net kararı.</p>
      </div>
    </div>
    <div class="grid">
      {tripData.segmentGuides.map((segment) => (
        <article class="card col-6">
          <div class="day-link">
            <strong>{segment.segment}</strong>
            <span class="tag tag--road">{segment.from} → {segment.to}</span>
          </div>
          <div class="hl-tags">
            {segment.highlights.map((item) => <span class="tag">{item}</span>)}
          </div>
          <div class="net-note">
            <strong>Net karar:</strong> {segment.netComment}
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="shell" id="strateji">
    <div class="sec-head">
      <span class="eyebrow">Saha Stratejisi</span>
      <h2>Yeme-içme ve mola modeli</h2>
      <p class="subline">Kahve, yemek ve kamp seçimi için sabit kurallar.</p>
    </div>
    <div class="grid">
      <article class="card col-6">
        <div class="card-head"><span class="flag">☕</span><h4>{tripData.coffeeStrategy.title}</h4></div>
        <ul class="strat-list">
          {tripData.coffeeStrategy.coffeeStops.map((item) => <li>{item}</li>)}
        </ul>
      </article>
      <article class="card col-6">
        <div class="card-head"><span class="flag">🍽️</span><h4>{tripData.mealStrategy.title}</h4></div>
        <ul class="strat-list">
          {tripData.mealStrategy.items.map((item) => <li>{item}</li>)}
        </ul>
      </article>
    </div>

    <div class="card col-12" style="margin-top: 16px;">
      <div class="card-head"><span class="flag">⛺</span><h4>{tripData.campLogic.title}</h4></div>
      <p class="subline">Her durakta tek kampa güvenme: ana tercih + yedek plan.</p>
      <div class="grid">
        {tripData.campLogic.items.map((item) => (
          <details class="col-6">
            <summary>{item.city}</summary>
            <div class="camp-split">
              <div class="camp-opt camp-opt--primary">
                <span class="camp-opt__tag">✓ Ana tercih</span>
                {item.primary}
              </div>
              <div class="camp-opt camp-opt--alt">
                <span class="camp-opt__tag">↺ Alternatif</span>
                {item.alternative}
              </div>
            </div>
            <p class="muted"><strong>Avantaj:</strong> {item.advantages}</p>
            <p class="muted"><strong>Dezavantaj:</strong> {item.disadvantages}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section id="plan" class="shell">
    <div class="sec-head">
      <span class="eyebrow">Gün Gün Plan · {daySpan} etap</span>
      <h2>Günlük Yolculuk Planı</h2>
      <p class="subline">Her güne tıklayarak risk, alternatif ve kamp detaylarına in.</p>
    </div>
    <div class="timeline">
      {tripData.days.map((day, i) => {
        const level = dayLevel(day);
        const rest = day.origin === day.destination;
        return (
          <a href={`/day/${day.slug}`} class="t-item">
            <span class:list={['t-node', { 't-node--rest': rest }]}>{rest ? '☾' : i + 1}</span>
            <div class="t-card">
              <div class="t-head">
                <span class="t-date">{day.date}</span>
                <span class={`lvl lvl--${level}`}>{levelText[level]}</span>
              </div>
              <div class="t-route">
                {rest ? `${day.origin} · Dinlenme günü` : <>{day.origin}<em>→</em>{day.destination}</>}
              </div>
              <div class="tag-row">
                {!rest && <span class="tag">🛣️ {day.distanceKm}</span>}
                <span class="tag">⏱️ {day.duration}</span>
                {!rest && <span class="tag">⛽ {day.fuel}</span>}
              </div>
              <p class="muted t-risk">{day.risks[0]}</p>
              <div class="t-foot">
                <span class="pill">⛺ {day.camp.place}</span>
                <span class="t-go">Günün detayı →</span>
              </div>
            </div>
          </a>
        );
      })}
    </div>
  </section>
</MainLayout>

<script
  is:inline
  lang="ts"
  define:vars={{ routeData: tripData.routeGuide, stopsData: tripData.stops, checklistSize: tripData.checklist.length, departureAt: tripData.departureAt }}
>
  (() => {
    const departure = new Date(departureAt);
    const departureValid = !isNaN(departure.getTime());
    const tiles = document.getElementById('count-tiles');
    const ctD = document.getElementById('ct-d');
    const ctH = document.getElementById('ct-h');
    const ctM = document.getElementById('ct-m');
    const ctS = document.getElementById('ct-s');
    const distEl = document.getElementById('remaining-distance');
    const timeEl = document.getElementById('remaining-time');
    const cityEl = document.getElementById('target-city');
    const locStatus = document.getElementById('location-status');
    const statusEl = document.getElementById('task-status');
    const progressEl = document.getElementById('task-progress');

    const pad = (n) => String(n).padStart(2, '0');
    let live = false;

    const updateCountdown = () => {
      if (!departureValid || !tiles || live) return;
      const diff = departure.getTime() - Date.now();
      if (diff <= 0) {
        live = true;
        tiles.innerHTML = '<div class="ct ct--live">🚐 Yoldayız!</div>';
        return;
      }
      if (ctD) ctD.textContent = String(Math.floor(diff / 86400000));
      if (ctH) ctH.textContent = pad(Math.floor((diff % 86400000) / 3600000));
      if (ctM) ctM.textContent = pad(Math.floor((diff % 3600000) / 60000));
      if (ctS) ctS.textContent = pad(Math.floor((diff % 60000) / 1000));
    };

    updateCountdown();
    const countdownInterval = setInterval(updateCountdown, 1000);
    window.addEventListener('pagehide', () => clearInterval(countdownInterval));

    const route = routeData;
    if (route.length > 0 && cityEl) {
      cityEl.textContent = route[0].to || 'Sofya';
    }

    const haversine = (a, b) => {
      const toRad = (d) => (d * Math.PI) / 180;
      const R = 6371;
      const dLat = toRad(b.lat - a.lat);
      const dLng = toRad(b.lng - a.lng);
      const sinLat = Math.sin(dLat / 2);
      const sinLng = Math.sin(dLng / 2);
      const aa =
        sinLat * sinLat +
        Math.cos(toRad(a.lat)) * Math.cos(toRad(b.lat)) * sinLng * sinLng;
      return 2 * R * Math.atan2(Math.sqrt(aa), Math.sqrt(1 - aa));
    };

    const stops = stopsData;
    const riga = stops[stops.length - 1];

    const setTaskProgress = () => {
      const checks = document.querySelectorAll('.task-check');
      let done = 0;
      checks.forEach((input) => {
        if (input.checked) done += 1;
      });
      const total = Number(checklistSize || 1);
      const percent = Math.round((done / total) * 100);
      statusEl.textContent = `${done} / ${total}`;
      progressEl.style.width = `${percent}%`;
    };

    // Kuzey iOS uygulamasının yayınladığı canlı konumu çek (60 sn'de bir).
    const liveBadge = document.getElementById('live-badge');
    const nearestEl = document.getElementById('nearest-stop');
    const speedEl = document.getElementById('live-speed');
    const updatedEl = document.getElementById('live-updated');

    const pollLive = async () => {
      try {
        const res = await fetch('/api/location', { cache: 'no-store' });
        if (!res.ok) return;
        const data = await res.json();
        if (typeof data.lat !== 'number') return;

        const current = { lat: data.lat, lng: data.lng };
        const remainingKm = haversine(current, riga);
        distEl.textContent = `${Math.round(remainingKm)} km`;

        let best = null;
        for (const s of stops) {
          const d = haversine(current, s);
          if (!best || d < best.d) best = { s, d };
        }
        if (best && nearestEl) nearestEl.textContent = `${best.s.name} · ${Math.round(best.d)} km`;
        if (speedEl) speedEl.textContent = data.speedKmh != null ? `${data.speedKmh} km/s` : '—';

        const ts = new Date(data.ts);
        if (updatedEl && !isNaN(ts.getTime())) {
          updatedEl.textContent = `Son güncelleme: ${ts.toLocaleTimeString('tr-TR', { hour: '2-digit', minute: '2-digit' })}`;
        }
        if (liveBadge) liveBadge.hidden = false;
        if (locStatus) locStatus.textContent = 'Karavandan canlı veri alınıyor.';
      } catch (_) {
        /* sessiz: app henüz yayın yapmıyor olabilir */
      }
    };

    const checks = document.querySelectorAll('.task-check');
    checks.forEach((item) => {
      const key = `trip-check-${item.dataset.task}`;
      const saved = localStorage.getItem(key) === '1';
      item.checked = saved;
      item.addEventListener('change', () => {
        localStorage.setItem(key, item.checked ? '1' : '0');
        setTaskProgress();
      });
    });

    setTaskProgress();
    pollLive();
    const liveInterval = setInterval(pollLive, 60000);
    window.addEventListener('pagehide', () => clearInterval(liveInterval));

    if ('serviceWorker' in navigator) {
      navigator.serviceWorker.register('/sw.js').catch(() => {});
    }
  })();
</script>
