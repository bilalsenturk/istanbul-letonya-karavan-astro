---
import MainLayout from '../../layouts/MainLayout.astro';
import RouteMap from '../../components/RouteMap.astro';
import RouteStepper from '../../components/RouteStepper.astro';
import CameraPlayer from '../../components/CameraPlayer.astro';
import { tripData } from '../../data/tripData';

export function getStaticPaths() {
  return tripData.days.map((day) => ({
    params: { slug: day.slug },
  }));
}

const { slug } = Astro.params;
const day = tripData.days.find((row) => row.slug === slug);

if (!day) {
  return Astro.redirect('/');
}

const mapStops = tripData.stops.map((stop) => ({ name: stop.name, lat: stop.lat, lng: stop.lng }));
const stepperStops = tripData.stops.map((stop) => ({ name: stop.name, country: stop.country }));
const dayIndex = tripData.days.findIndex((row) => row.slug === slug);
const previous = dayIndex - 1;
const next = dayIndex + 1;

const matchedSegmentGuide = tripData.segmentGuides.find((segment) => {
  const fromMatch = segment.from === day.origin || day.origin.includes(segment.from) || segment.from.includes(day.origin);
  const toMatch =
    segment.to === day.destination ||
    day.destination.includes(segment.to) ||
    segment.to.includes(day.destination);
  return fromMatch && toMatch;
});

const segmentGuide = matchedSegmentGuide ?? tripData.segmentGuides[Math.max(0, Math.min(dayIndex - 1, tripData.segmentGuides.length - 1))];

const cityToCountry: Array<[string, string]> = [
  ['İstanbul', 'Türkiye'],
  ['Sofya', 'Bulgaristan'],
  ['Bükreş', 'Romanya'],
  ['Deva', 'Romanya'],
  ['Budapeşte', 'Macaristan'],
  ['Katowice', 'Polonya'],
  ['Suwałki', 'Polonya'],
  ['Riga', 'Letonya'],
];

const dayCountries = Array.from(
  new Set(
    cityToCountry
      .filter(([city]) => day.origin.includes(city) || day.destination.includes(city))
      .map(([, country]) => country),
  ),
);

const dayCountryGuides = dayCountries
  .map((country) => tripData.countryGuides.find((guide) => guide.country === country))
  .filter((guide): guide is NonNullable<(typeof tripData.countryGuides)[number]> => Boolean(guide));

// Bu günün hedef durağını stepper'da aktif olarak işaretle.
const activeIndex = (() => {
  const found = tripData.stops.findIndex(
    (s) => day.destination.includes(s.name) || s.name.includes(day.destination),
  );
  return found >= 0 ? found : Math.min(dayIndex + 1, tripData.stops.length - 1);
})();
---

<MainLayout title={`Günlük Plan: ${day.date} (${day.origin} → ${day.destination})`}>
  <section class="shell" id="top">
    <div class="day-title">
      <h1>{day.date}</h1>
      <span class="tag tag--road">{day.origin} → {day.destination}</span>
    </div>
    <p class="subline">
      Günün operasyonel özeti: mesafe, yakıt, risk senaryoları, alternatif planlar, kamp teyidi ve kamera takip noktaları.
    </p>
    <p class="tag-row">
      <span class="tag">Mesafe: {day.distanceKm}</span>
      <span class="tag">Sürüş: {day.duration}</span>
      <span class="tag">Yakıt: {day.fuel}</span>
    </p>
    <div class="hero-stepper">
      <RouteStepper stops={stepperStops} activeIndex={activeIndex} />
    </div>
  </section>

  <section class="grid">
    <article class="card col-8">
      <div class="section-title">
        <h3>Rota ve Plan</h3>
        <a class="btn btn--ghost" href="/">Kontrol Paneli</a>
      </div>
      <RouteMap
        title="Günün Haritası"
        routeStops={mapStops}
        activeFrom={day.origin}
        activeTo={day.destination}
        height="420px"
      />
      <div class="two-col" style="margin-top:10px;">
        <div>
          <h4>Kamp</h4>
          <p><strong>{day.camp.name}</strong> — {day.camp.place}</p>
          <p class="muted">{day.camp.note}</p>
          <p>İletişim: {day.camp.contact}</p>
          {day.camp.email ? <p>E-posta: <a href={`mailto:${day.camp.email}`}>{day.camp.email}</a></p> : null}
          {day.camp.phone ? <p>Tel: <a href={`tel:${day.camp.phone}`}>{day.camp.phone}</a></p> : null}
          <p>Rezervasyon şablonu: <em>{day.camp.reservationTemplate}</em></p>
          <p><a href={day.camp.link} target="_blank" rel="noreferrer">Kamp konumu</a></p>
        </div>
        <div>
          <h4>Canlı Trafik Kontrolü</h4>
          <p class="subline" style="margin-bottom: 12px;">
            Trafik izleme için en stabil seçenek doğrudan harita uygulamasını yeni sekmede açmaktır.
          </p>
          <p class="tag-row">
            <a
              class="btn"
              href={`https://www.google.com/maps/dir/?api=1&origin=${encodeURIComponent(day.origin)}&destination=${encodeURIComponent(day.destination)}&travelmode=driving`}
              target="_blank"
              rel="noreferrer"
            >
              Google Yol Trafiği (Canlı)
            </a>
            <a class="btn btn--ghost" href={day.route} target="_blank" rel="noreferrer">Google Rota Planını Aç</a>
          </p>
          <p class="muted">Not: Bu planın trafik penceresi kaynaktan kısıtlanabiliyor, bu yüzden bağlantılar tercih edilir.</p>
        </div>
      </div>
      <div class="tag-row">
          <a class="btn btn--primary" href={day.route} target="_blank" rel="noreferrer">Google Rota Planı</a>
          <a class="btn btn--ghost" href="/#harita">Kontrol Paneli Rotası</a>
          <a class="btn btn--ghost" href="/">Kontrol Paneline Dön</a>
      </div>
    </article>

    <article class="card col-4">
      <div class="section-title">
        <h3>Riskler ve Olasılıklar</h3>
        <span class="pill">Strateji odaklı</span>
      </div>
      <h4>Sorun Senaryoları</h4>
      <ul>
        {day.risks.map((item) => <li>{item}</li>)}
      </ul>
      <h4>Fırsat ve alternatifler</h4>
      <ul>
        {day.opportunities.map((item) => <li>{item}</li>)}
      </ul>
      <h4>Kontenjan / Yedek Plan</h4>
      <ul>
        {day.contingencies.map((item) => <li>{item}</li>)}
      </ul>
    </article>
  </section>

  <section class="shell">
    <div class="section-title">
      <h3>Etap Brifingi</h3>
      <a class="btn btn--ghost" href="#top">Ana başlık</a>
    </div>
    <div class="grid">
      <article class="card col-6">
        <h4>Güzergâh özeti</h4>
        <p class="muted">{day.origin} → {day.destination}</p>
        <ul>
          {segmentGuide.highlights.map((item) => <li>{item}</li>)}
        </ul>
        <p><strong>Net yorum:</strong> {segmentGuide.netComment}</p>
      </article>

      <article class="card col-6">
        <h4>Ülke odaklı operatif notlar</h4>
        {dayCountryGuides.map((guide) => (
          <details class="accordion">
            <summary>{guide.country}</summary>
            <p>{guide.profile}</p>
            <p class="muted">
              {guide.population} · {guide.language} · {guide.currency}
            </p>
            <p><strong>Öne çıkan:</strong></p>
            <ul>
              {guide.highlights.map((point) => <li>{point}</li>)}
            </ul>
            <p class="muted">{guide.highlightsAdvice}</p>
            <p>
              <strong>Önerilen alışveriş/ara nokta:</strong> {guide.shopping}
            </p>
            {guide.shoppingAdvice ? <p class="muted">{guide.shoppingAdvice}</p> : null}
            <p class="muted">{guide.coffeeFood}</p>
            <p class="muted"><strong>Not:</strong> {guide.roadNote}</p>
          </details>
        ))}
      </article>
    </div>
  </section>

  <section class="shell">
    <div class="section-title">
      <h3>Yol Üzeri Duraklar</h3>
      <span class="pill">Yakıt-kahve-tavsiyeler</span>
    </div>
    <div class="grid">
      {day.stops.map((stop) => (
        <article class="card col-4">
          <h4>{stop.type} · {stop.name}</h4>
          <p>{stop.note}</p>
          <p class="tag-row">
            <span class="tag">~{stop.estimatedMinutes} dk</span>
            <a class="btn" href={stop.mapUrl} target="_blank" rel="noreferrer">Haritada Aç</a>
          </p>
        </article>
      ))}
    </div>
  </section>

  <section class="shell">
    <div class="section-title">
      <h3>Şehir Kameraları</h3>
      <a class="btn btn--ghost" href="#top">Yukarı çık</a>
    </div>
    <div class="grid">
      {day.cityCameras.map((camera) => <div class="col-6"><CameraPlayer camera={camera} /></div>)}
    </div>
  </section>

  <section class="shell">
    <h3>İleriye Yönelik Notlar</h3>
    <p class="subline">Riga sonrası adaptasyon ve 2. haftaya geçişte kullanılan aksiyon kartları.</p>
    <div class="grid">
      {tripData.postArrival.map((item) => (
        <article class="card col-4">
          <strong>{item.when}</strong>
          <h4>{item.title}</h4>
          <p>{item.text}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="shell">
    <h3>Geçiş Bağlantıları</h3>
    <p class="tag-row">
      {previous >= 0 ? <a class="btn" href={`/day/${tripData.days[previous].slug}`}>Önceki Gün</a> : null}
      {next < tripData.days.length ? <a class="btn btn--ghost" href={`/day/${tripData.days[next].slug}`}>Sonraki Gün</a> : null}
    </p>
  </section>
</MainLayout>

<style>
  h4 {
    margin-bottom: 6px;
  }

  ul {
    margin: 4px 0 14px 0;
    padding-left: 18px;
  }

  li {
    margin: 6px 0;
  }

  iframe {
    width: 100%;
    min-height: 240px;
    border: 1px solid rgba(120, 150, 210, 0.35);
    border-radius: 10px;
  }

  .day-title {
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 10px;
    align-items: center;
  }

  .day-title h1 {
    margin: 0;
    font-size: 1.5rem;
  }
</style>
