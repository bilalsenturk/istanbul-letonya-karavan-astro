---
interface Camera {
  title: string;
  url: string;
  source: string;
  kind?: 'video' | 'web';
}

interface Props {
  camera: Camera;
}

const { camera } = Astro.props;
const containerId = `camera-${Math.random().toString(36).slice(2, 8)}`;
---

<article class="card">
  <div class="day-title">
    <h4>{camera.title}</h4>
    <span class="muted">{camera.source}</span>
  </div>

  {camera.kind === 'video' ? (
    <div class="custom-player">
      <iframe
        id={containerId}
        src={camera.url}
        loading="lazy"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
        allowfullscreen
        title={camera.title}
      ></iframe>
      <div class="player-overlay">
        <a class="open-link" href={camera.url} target="_blank" rel="noreferrer">Kamerayı kendi pencerende aç</a>
      </div>
    </div>
  ) : (
    <div class="camera-frame">
      <iframe src={camera.url} loading="lazy" title={camera.title}></iframe>
    </div>
  )}
</article>

<style>
  article {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .custom-player,
  .camera-frame {
    position: relative;
    border-radius: 10px;
    overflow: hidden;
    border: 1px solid rgba(120, 150, 210, 0.4);
  }

  .custom-player iframe,
  .camera-frame iframe {
    width: 100%;
    aspect-ratio: 16 / 9;
    border: 0;
    display: block;
  }

  .player-overlay {
    position: absolute;
    inset: auto 0 0 0;
    padding: 8px;
    background: linear-gradient(transparent, rgba(7, 14, 24, 0.72));
    display: flex;
    justify-content: flex-end;
  }

  .open-link {
    font-size: 12px;
    background: rgba(7, 14, 24, 0.8);
    border: 1px solid rgba(120, 150, 210, 0.5);
    padding: 6px 10px;
    border-radius: 999px;
    color: #d7e7ff;
  }

  .day-title {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
  }

  .day-title h4 {
    margin: 0;
    font-size: 0.95rem;
  }

  .day-title span {
    color: #9eb2d1;
    font-size: 12px;
    white-space: nowrap;
  }
</style>
