---
interface Stop {
  name: string;
  lat: number;
  lng: number;
}

interface Props {
  title: string;
  routeStops: Stop[];
  activeFrom: string;
  activeTo: string;
  height?: string;
}

const { title, routeStops, activeFrom, activeTo, height = '360px' } = Astro.props;
const mapId = `route-map-${Math.random().toString(36).slice(2, 10)}`;
const validStops = routeStops.filter((stop) => Number.isFinite(stop.lat) && Number.isFinite(stop.lng));
const fallbackCenter = (() => {
  if (!validStops.length) return '55.0000,24.0000';
  const avgLat = validStops.reduce((total, stop) => total + stop.lat, 0) / validStops.length;
  const avgLng = validStops.reduce((total, stop) => total + stop.lng, 0) / validStops.length;
  return `${avgLat.toFixed(4)},${avgLng.toFixed(4)}`;
})();
const fallbackMarkers = validStops.map((stop) => `&markers=${stop.lat.toFixed(4)},${stop.lng.toFixed(4)},lightblue1`).join('');
const fallbackUrl = `https://staticmap.openstreetmap.de/staticmap.php?size=900x420&zoom=6&center=${encodeURIComponent(fallbackCenter)}&maptype=mapnik${fallbackMarkers}`;
---

<section class="card" aria-label={title}>
  <h3>{title}</h3>
  <div class:list={["map-frame", "route-map-container"]} style={`height:${height}; position:relative;`}>
    <div
      id={mapId}
      class="route-map"
      data-stops={JSON.stringify(routeStops)}
      data-from={activeFrom}
      data-to={activeTo}
      style={`height:${height}; min-height:${height};`}
    ></div>
    <div class="fallback-map">
      <img
        class="fallback-map-image"
        loading="lazy"
        src={fallbackUrl}
        alt="Yol haritası arka plan"
      />
    </div>
  </div>
</section>

<style>
  .route-map {
    position: absolute;
    inset: 0;
    z-index: 1;
  }

  .route-map-container {
    min-height: 320px;
  }

  .route-map-container:not(.ready) .route-map {
    opacity: 0;
  }

  .route-map-container.ready .fallback-map {
    display: none;
  }

  .route-map-container.ready .route-map {
    opacity: 1;
  }

  .fallback-map {
    position: absolute;
    inset: 0;
    z-index: 2;
  }

  .fallback-map img,
  .fallback-map {
    display: block;
  }

  .fallback-map-image {
    width: 100%;
    height: 100%;
    border: none;
    object-fit: cover;
    min-height: 100%;
  }

  .fallback-map {
    background: #091427;
  }
</style>

<script>
  import { initRouteMap } from '../scripts/routeMap';

  document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('.route-map').forEach((el) => {
      if (el.id) initRouteMap(el.id);
    });
  });
</script>
